{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/KeyMagic.Service/KeyMagic.Service.csproj",
        "--configuration",
        "Debug"
      ],
      "problemMatcher": "$msCompile",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "build-tester",
      "command": "dotnet",
      "type": "process",
      "args": [
        "build",
        "${workspaceFolder}/src/KeyMagic.Tester/KeyMagic.Tester.csproj",
        "--configuration",
        "Debug"
      ],
      "problemMatcher": "$msCompile",
      "presentation": {
        "reveal": "silent"
      }
    },
    {
      "label": "publish",
      "command": "dotnet",
      "type": "process",
      "args": [
        "publish",
        "${workspaceFolder}/src/KeyMagic.Service/KeyMagic.Service.csproj",
        "--configuration",
        "Release",
        "--runtime",
        "win-x64",
        "--self-contained",
        "--output",
        "${workspaceFolder}/artifacts/publish/win-x64"
      ],
      "problemMatcher": "$msCompile"
    }
  ]
}
